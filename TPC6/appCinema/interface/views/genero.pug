extends layout

block content
  .w3-card-4
    header.w3-container.w3-teal
      h1 #{g.name}

    .w3-container
      table.w3-table-all.w3-margin-top
        tr
          th Filmes

        each f in g.films
          tr.w3-hover-dark-grey(
            onclick=`window.location='/filmes/${f._id}'`
            style="cursor:pointer"
          )
            td= f.title

  footer.w3-container.w3-light-grey
    a.w3-btn.w3-round.w3-blue-grey.w3-margin-right(href="/generos") Voltar