extends layout

block content
    .w3-card-4
        header.w3-container.w3-teal
            h1 Estatísticas

        .w3-container
            table.w3-table-all.w3-margin-top
                tr
                    th Género
                    th Número de Atletas
                each num, genero in generos
                    tr
                        td= genero
                        td= num

        .w3-container
            table.w3-table-all.w3-margin-top
                tr
                    th Modalidades
                    th Número de Atletas
                each num, modalidade in modalidades
                    tr
                        td= modalidade
                        td= num

        .w3-container
            table.w3-table-all.w3-margin-top
                tr
                    th Clubes
                    th Número de Atletas
                each num, clube in clubes
                    tr
                        td= clube
                        td= num

        .w3-container
            table.w3-table-all.w3-margin-top
                tr
                    th Resultados
                    th Número de Atletas
                each num, resultado in resultados
                    tr
                        td= resultado
                        td= num

        .w3-container
            table.w3-table-all.w3-margin-top
                tr
                    th Atletas Federados
                    th Número de Atletas
            each num, federado in federados
                    tr
                        td= federado
                        td= num
        .w3-container
        a.w3-button.w3-teal.w3-medium.w3-margin-top.w3-left.w3-margin(href="/") Voltar ao início