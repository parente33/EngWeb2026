extends ../layout

block content
  h2 Índice Antroponímico
  p.w3-text-grey #{nomes.length} nomes encontrados

  //- Navegação por letra
  .w3-bar.w3-margin-bottom
    each letra in 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('')
      a.w3-button.w3-small.w3-grey.w3-margin-right(href=`#letra-${letra}`) #{letra}

  //- Lista agrupada por letra inicial
  - var letraAtual = ''
  each nome in nomes
    - var inicial = nome[0].toUpperCase()
    if inicial !== letraAtual
      - letraAtual = inicial
      h3.w3-text-dark-grey(id=`letra-${inicial}`) #{inicial}
      hr
    a.w3-button.w3-block.w3-left-align.w3-white.w3-border-bottom(href=`/inquiricoes?requerente=${encodeURIComponent(nome)}`) #{nome}
