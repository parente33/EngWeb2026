extends layout

block content
  .w3-container.w3-teal
    h1 Lista de Atores

  .w3-container.w3-margin-top
    table.w3-table-all.w3-hoverable
      thead
        tr.w3-light-grey
          th ID
          th Ator
          th #Filmes
      tbody
        each a in atores
          tr
            td: a(href="/atores/" + a.id) #{a.id}
            td: a(href="/atores/" + a.id) #{a.actor}
            td: a(href="/atores/" + a.id) #{a.movies.length}